# Backend environment variables — copy this file to .env and fill in real values.
# The .env file is gitignored and must never be committed.

# MongoDB connection string (from your MongoDB Atlas cluster).
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_URL=

# Secret used to sign session cookies. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=

# Allowed frontend origin for CORS (the Vite dev server).
CLIENT_ORIGIN=http://localhost:5173

# Port the backend listens on.
PORT=5001

# Frontend (Vite) — base URL of the backend API.
# IMPORTANT: Vite bakes this in at BUILD time, so it must be set when the
# frontend is built/deployed (e.g. https://your-backend.up.railway.app).
VITE_API_URL=http://localhost:5001
